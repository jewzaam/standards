# Generated By: Claude Code (Claude Opus 4.7)
# Optional target: detect hallucinated imports and missing file references.
# Copy to make/fabcheck.mk and add to Makefile: -include make/fabcheck.mk
# Also vendor scripts/fabcheck.sh from build/templates/fabcheck.sh.
#
# Dependencies:
#   - git, jq, bash (always required)
#   - python3 on PATH (only when Python files are in scope; required for
#     accurate dist-name -> import-name resolution via importlib.metadata)
# The JavaScript / Go / Rust / Shell checks remain pure bash.

.PHONY: fabcheck fabcheck-report

# FABCHECK_OUTDIR follows the .tmp-<slug>/ convention (common/tmp-dirs.md):
# a visible, git-ignored working directory that persists across runs so the
# last verdict.json can be inspected in place. fabcheck.sh drops a single-line
# `*` .gitignore on first write.
FABCHECK_OUTDIR     ?= .tmp-fabcheck
FABCHECK_RANGE      ?=
FABCHECK_LANGUAGES  ?=

fabcheck:  ## Detect hallucinated imports and missing file refs across tracked code
	@bash scripts/fabcheck.sh \
		--out-dir "$(FABCHECK_OUTDIR)" \
		$(if $(FABCHECK_RANGE),--range "$(FABCHECK_RANGE)") \
		$(if $(FABCHECK_LANGUAGES),--language "$(FABCHECK_LANGUAGES)")

fabcheck-report:  ## Print last fabcheck result summary
	@test -f "$(FABCHECK_OUTDIR)/verdict.json" \
		&& jq -r '"scanned=\(.files_scanned) missing=\(.missing) warn=\(.warn) ok=\(.ok_count) result=\(.result)"' "$(FABCHECK_OUTDIR)/verdict.json" \
		|| echo "No fabcheck run yet - run 'make fabcheck'"
